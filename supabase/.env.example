# Supabase / Edge Function Secrets
# ─────────────────────────────────────────────────────────────────────────────
# Quick start:
#   ./scripts/setup-env.sh          # copies this template → supabase/.env
#   agentsentinel-config-check       # validates all required vars
#
# Deploy to Supabase after filling in real values:
#   supabase secrets set --env-file supabase/.env
#
# Variables marked __GENERATE_HEX_32__ / __GENERATE_BASE64_64__ are auto-filled
# by setup-env.sh.  Do NOT commit this file with real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ─────────────────────────────────────────────────────────────────
# Purpose:     Supabase project URL (used by every Edge Function).
# Required:    yes — dev + prod + all edge functions
# How to get:  https://supabase.com/dashboard → project Settings → API
# Example:     https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Purpose:     Supabase service-role key — bypasses RLS.  Server-side only!
# Required:    yes — dev + prod + all edge functions
# How to get:  https://supabase.com/dashboard → project Settings → API → service_role
# Example:     eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Purpose:     Supabase anon key (safe to expose in front-end/SDK code).
# Required:    yes — front-end + SDK
# How to get:  https://supabase.com/dashboard → project Settings → API → anon public
# Example:     eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=your_anon_key_here


# ── Stripe ───────────────────────────────────────────────────────────────────
# Purpose:     Stripe secret key — used by Edge Functions to create sessions, etc.
# Required:    yes — dev + prod
# How to get:  https://dashboard.stripe.com/apikeys  (keep secret!)
# Example:     sk_live_xxxxxxxxxxxx  (test: sk_test_xxxxxxxxxxxx)
STRIPE_SECRET_KEY=sk_live_your_key_here

# Purpose:     Stripe webhook signing secret — verifies webhook payload authenticity.
# Required:    yes — prod (stripe-webhook Edge Function)
# How to get:  https://dashboard.stripe.com/webhooks → select endpoint → signing secret
# Example:     whsec_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Purpose:     Stripe Price ID for the Starter tier.
# Required:    yes — prod (stripe-webhook maps price IDs to license tiers)
# How to get:  https://dashboard.stripe.com/products → Starter product → price ID
# Example:     price_1Nxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxx

# Purpose:     Stripe Price ID for the Pro tier.
# Required:    yes — prod
# How to get:  https://dashboard.stripe.com/products → Pro product → price ID
# Example:     price_1Nxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxx

# Purpose:     Stripe Price ID for the Pro Team tier (base subscription).
# Required:    yes — prod
# How to get:  https://dashboard.stripe.com/products → Pro Team product → base price ID
# Example:     price_1Nxxxxxxxxxxxxx
STRIPE_PRICE_PRO_TEAM=price_xxxxx

# Purpose:     Stripe Price ID for the Enterprise tier.
# Required:    yes — prod
# How to get:  https://dashboard.stripe.com/products → Enterprise product → price ID
# Example:     price_1Nxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# Purpose:     Stripe Price ID for the Pro Team per-seat base charge.
# Required:    yes — prod (checkout-team Edge Function)
# How to get:  https://dashboard.stripe.com/products → Pro Team → base price ID
# Example:     price_1Nxxxxxxxxxxxxx
STRIPE_PRICE_PRO_TEAM_BASE=price_xxxxx

# Purpose:     Stripe Price ID for each additional Pro Team seat.
# Required:    yes — prod (checkout-team Edge Function)
# How to get:  https://dashboard.stripe.com/products → Pro Team → per-seat price ID
# Example:     price_1Nxxxxxxxxxxxxx
STRIPE_PRICE_PRO_TEAM_SEAT=price_xxxxx


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Purpose:     API key for Resend — sends license delivery and OTP emails.
# Required:    yes — prod (stripe-webhook, send-portal-otp)
# How to get:  https://resend.com/api-keys
# Example:     re_xxxxxxxxxxxx
RESEND_API_KEY=re_your_key_here


# ── License key signing secret ────────────────────────────────────────────────
# Purpose:     HMAC secret for asv1_ license key generation and verification.
#              Also signs portal_token values (create-billing-session).
#              MUST match AGENTSENTINEL_LICENSE_SIGNING_SECRET in Python SDK.
# Required:    yes — dev + prod + all edge functions that issue/verify keys
# How to get:  openssl rand -hex 32
# Example:     (64 hex chars)
AGENTSENTINEL_LICENSE_SIGNING_SECRET=__GENERATE_HEX_32__


# ── Admin API secret ─────────────────────────────────────────────────────────
# Purpose:     Bearer token that protects admin-only endpoints
#              (e.g. admin-generate-promo Edge Function).
#              Must match ADMIN_API_SECRET in the admin dashboard config.
# Required:    yes — dev + prod (admin operations)
# How to get:  openssl rand -hex 32
# Example:     (64 hex chars)
ADMIN_API_SECRET=__GENERATE_HEX_32__


# ── Site URL ─────────────────────────────────────────────────────────────────
# Purpose:     Base URL used for Stripe redirect URLs after checkout.
# Required:    yes — prod
# How to get:  n/a — set to your deployment URL
# Example:     https://agentsentinel.net
SITE_BASE_URL=https://agentsentinel.net


# ── Customer Dashboard ────────────────────────────────────────────────────────
# Purpose:     Base URL for customer-facing dashboard pages.
#              Dashboard URLs follow the pattern:
#              {CUSTOMER_DASHBOARD_BASE_URL}/d/{customer_id}/{dashboard_token}
#              Used by stripe-webhook when emailing the "Launch Dashboard" link.
# Required:    yes — prod (stripe-webhook, customer-dashboard edge function)
# How to get:  n/a — set to where dashboard/onboarding.html and dashboard/main.html
#              are hosted (e.g. same domain as main site or a dedicated subdomain).
# Example:     https://dash.agentsentinel.net
#              https://agentsentinel.net/dashboard
CUSTOMER_DASHBOARD_BASE_URL=https://dash.agentsentinel.net

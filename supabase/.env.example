# Supabase (auto-configured when deploying)
# Replace hjjeowbgqyabpacxqbww with your own Supabase project reference.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (set after creating products in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_PRO_TEAM=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# Pro Team per-seat pricing (used by checkout-team Edge Function)
STRIPE_PRICE_PRO_TEAM_BASE=price_xxxxx
STRIPE_PRICE_PRO_TEAM_SEAT=price_xxxxx

# Resend (Email delivery — used for license emails and OTP codes)
RESEND_API_KEY=re_your_key_here

# License key signing secret
# - Used by HMAC-signed asv1_ license key generation and verification.
# - Also used to sign portal_token values for create-billing-session.
# - Must match AGENTSENTINEL_LICENSE_SIGNING_SECRET set in the Python/JS SDKs.
# - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGENTSENTINEL_LICENSE_SIGNING_SECRET=your_signing_secret_here

# Site base URL (used for Stripe redirect URLs)
SITE_BASE_URL=https://agentsentinel.net

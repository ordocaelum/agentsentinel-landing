# AgentSentinel Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Quick start:
#   ./scripts/setup-env.sh          # generates secrets, copies template → .env
#   agentsentinel-config-check       # validates all required vars
#
# Variables marked __GENERATE_HEX_32__ / __GENERATE_BASE64_64__ are auto-filled
# by setup-env.sh.  Do NOT commit this file with real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── License signing secret ───────────────────────────────────────────────────
# Purpose:     HMAC-signs asv1_ license keys and portal_token values.
# Required:    yes — dev + prod + SDK (Python and Edge Functions must match)
# How to get:  openssl rand -hex 32
# Example:     (64 hex chars)
AGENTSENTINEL_LICENSE_SIGNING_SECRET=__GENERATE_HEX_32__

# ── License validation API URL ───────────────────────────────────────────────
# Purpose:     REST endpoint the Python SDK calls to validate a license key online.
# Required:    no (SDK falls back to offline HMAC check if unset)
# How to get:  n/a — default points to production API
# Example:     https://xxxxxxxxxxxxxxxxxxx.supabase.co/functions/v1/validate-license
AGENTSENTINEL_LICENSE_API=https://api.agentsentinel.net/v1/license/validate

# ── License key (SDK consumer) ───────────────────────────────────────────────
# Purpose:     License key used by the Python SDK to authenticate the caller.
# Required:    yes — prod SDK usage
# How to get:  Issued after purchase at https://agentsentinel.net/portal
# Example:     asv1_xxxxxxxxxxxxxxxxxxxx  or  as_pro_xxxxxxxxxxxx
AGENTSENTINEL_LICENSE_KEY=


# ── Stripe ───────────────────────────────────────────────────────────────────
# Purpose:     Stripe publishable key (front-end Stripe.js / checkout).
# Required:    yes — prod (front-end checkout pages)
# How to get:  https://dashboard.stripe.com/apikeys
# Example:     pk_live_xxxxxxxxxxxx  (test: pk_test_xxxxxxxxxxxx)
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# Purpose:     Stripe secret key (server-side API calls, webhook construction).
# Required:    yes — prod
# How to get:  https://dashboard.stripe.com/apikeys  (keep secret!)
# Example:     sk_live_xxxxxxxxxxxx  (test: sk_test_xxxxxxxxxxxx)
STRIPE_SECRET_KEY=sk_live_your_key_here

# Purpose:     Stripe webhook signing secret — verifies webhook payloads.
# Required:    yes — prod
# How to get:  https://dashboard.stripe.com/webhooks  → select endpoint → signing secret
# Example:     whsec_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here


# ── Dev / debug flags ────────────────────────────────────────────────────────
# Purpose:     Set to "true" to bypass the paid-licence gate in the Python SDK.
# Required:    no — dev only; NEVER set in production
# How to get:  n/a — set manually
# Example:     true
AGENTSENTINEL_DEV_MODE=false

# Purpose:     Set to "1" to enable dev-only endpoints in the admin dashboard
#              (e.g. /api/debug/static-status) and verbose logging.
# Required:    no — dev only; NEVER set in production
# How to get:  n/a — set manually
# Example:     1
AGENTSENTINEL_DEV=

# Purpose:     Set to "1" to enable verbose debug logging in the dashboard server.
# Required:    no
# How to get:  n/a
# Example:     1
AGENTSENTINEL_DASHBOARD_DEBUG=

# Purpose:     Override the default dashboard HTTP port (default: 8080).
# Required:    no
# How to get:  n/a
# Example:     9090
AGENTSENTINEL_DASHBOARD_PORT=

# Purpose:     Override the default dashboard bind host (default: localhost).
# Required:    no
# How to get:  n/a
# Example:     0.0.0.0
AGENTSENTINEL_DASHBOARD_HOST=


# ── Supabase (Python SDK / server-side) ──────────────────────────────────────
# Note: Supabase Edge Function secrets are configured separately via:
#   supabase secrets set KEY=value
# See supabase/.env.example for the full list of Supabase-specific secrets.
#
# Purpose:     Supabase project URL.
# Required:    yes — prod server-side calls
# How to get:  https://supabase.com/dashboard → project Settings → API
# Example:     https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Purpose:     Supabase service-role key (bypasses RLS — server-side only!).
# Required:    yes — prod
# How to get:  https://supabase.com/dashboard → project Settings → API → service_role
# Example:     eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=

# Purpose:     Supabase anon key (safe to expose in front-end code).
# Required:    yes — front-end / SDK
# How to get:  https://supabase.com/dashboard → project Settings → API → anon public
# Example:     eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=


# ── Admin API ────────────────────────────────────────────────────────────────
# Purpose:     Bearer token that protects admin-only Edge Function endpoints
#              (e.g. admin-generate-promo).  Must match the Supabase secret.
# Required:    yes — prod admin dashboard
# How to get:  openssl rand -hex 32
# Example:     (64 hex chars)
ADMIN_API_SECRET=__GENERATE_HEX_32__

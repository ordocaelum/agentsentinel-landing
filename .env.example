# AgentSentinel Environment Configuration
# Copy this to .env and fill in your values

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# License API
AGENTSENTINEL_LICENSE_API=https://api.agentsentinel.dev/v1/license/validate

# License signing secret (required for offline signed key verification)
AGENTSENTINEL_LICENSE_SIGNING_SECRET=replace_with_random_secret

# Development Mode (set to false in production!)
AGENTSENTINEL_DEV_MODE=false
